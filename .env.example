# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_secret

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: leave as default (./chainquest.db)
# Railway:   set to /data/chainquest.db  (volume mounted at /data)
DB_PATH=./chainquest.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# On Railway: your *.railway.app URL (or custom domain)
# Local dev:  not needed — defaults to localhost:5173 + localhost:3001
ALLOWED_ORIGINS=https://your-app.railway.app

# ─── Web3 / Sepolia (optional — leave blank for simulated mode) ───────────────
# Game is fully playable without these. Token rewards will be simulated.
# Get a free RPC key at https://alchemy.com or https://infura.io
SEPOLIA_RPC_URL=
# A Sepolia testnet wallet private key (never use a mainnet key)
MINTER_PRIVATE_KEY=
# Contract address — only set after running: npm run deploy:sepolia
VITE_CQT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_NETWORK_CHAIN_ID=11155111
