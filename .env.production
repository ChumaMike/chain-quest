# Vite env for Railway same-origin deployment
# Leave VITE_API_URL and VITE_WS_URL empty — relative paths work when the
# frontend is served by the same Express server (production Railway setup).
VITE_API_URL=
VITE_WS_URL=
VITE_NETWORK_CHAIN_ID=11155111
# Set VITE_CQT_CONTRACT_ADDRESS to the deployed Sepolia contract address.
# Run: node scripts/generate-wallet.js  → fund wallet → npm run deploy:sepolia
VITE_CQT_CONTRACT_ADDRESS=
