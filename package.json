{
  "name": "chain-quest",
  "version": "1.0.0",
  "description": "CHAIN QUEST: Gamified blockchain learning RPG with pixel open world, multiplayer, and Sepolia token rewards",
  "scripts": {
    "dev": "concurrently -k -n \"SERVER,CLIENT\" -c \"cyan,magenta\" \"node server/index.js\" \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "compile": "npx hardhat compile",
    "deploy:sepolia": "npx hardhat run scripts/deployToken.js --network sepolia"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ethers": "^6.11.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "framer-motion": "^11.0.8",
    "helmet": "^8.1.0",
    "howler": "^2.2.4",
    "jsonwebtoken": "^9.0.2",
    "phaser": "^3.60.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.2",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/howler": "^2.2.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "hardhat": "^2.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6"
  }
}
